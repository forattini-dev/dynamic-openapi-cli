{
  "name": "dynamic-openapi-cli",
  "version": "0.1.2",
  "description": "Transform any OpenAPI v3 spec into a fully functional CLI",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "dynamic-openapi-cli": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "openapi",
    "cli",
    "swagger",
    "api-client",
    "command-line",
    "rest"
  ],
  "license": "MIT",
  "dependencies": {
    "@readme/openapi-parser": "^4.1.0",
    "cli-args-parser": "^1.0.6",
    "openapi-types": "^12.1.3",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.2",
    "@vitest/coverage-v8": "^3.2.4",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
